# Local development defaults live here. The expected eventual always-on host
# for Tourney is an Oracle Cloud Always Free VM.
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-application-client-id
DISCORD_GUILD_ID=your-development-guild-id
# Keep this local during development. On Oracle, point it at a persisted data
# path on the VM so tournament state survives process restarts.
TOURNEY_DATA_DIR=./data
# Keep loopback for local work. On the Oracle VM, bind to 0.0.0.0 and set the
# base URL below to the stable public HTTPS organizer URL.
TOURNEY_ORGANIZER_HOST=127.0.0.1
TOURNEY_ORGANIZER_PORT=4318
TOURNEY_ORGANIZER_BASE_URL=http://127.0.0.1:4318
TOURNEY_MANAVAULT_API_BASE_URL=https://manavault.gg
TOURNEY_MANAVAULT_API_TOKEN=your-manavault-bot-token
TOURNEY_MANAVAULT_DECK_IMPORT_PATH=/api/bots/decks/import
TOURNEY_MANAVAULT_IMAGE_RECOGNITION_PATH=/api/bots/decks/recognize-image
TOURNEY_MANAVAULT_TOURNAMENT_PUBLISH_PATH=/api/bots/events
TOURNEY_MANAVAULT_TIMEOUT_MS=20000
