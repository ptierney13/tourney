{
  "name": "tourney",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot for tournament thread setup, decklist intake, and publishing.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "register": "tsx src/scripts/registerCommands.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "engines": {
    "node": ">=18.12"
  },
  "dependencies": {
    "discord.js": "^14.23.2",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@types/node": "^24.6.0",
    "eslint": "^8.57.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
